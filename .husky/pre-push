# Create logs directory if it doesn't exist
mkdir -p .husky/logs

# Run TypeScript type checking
echo "=== TypeScript check: $(date) ===" >> .husky/logs/tsc.log
pnpm exec tsc --noEmit 2>&1 | tee -a .husky/logs/tsc.log
TSC_EXIT=${PIPESTATUS[0]}

if [ $TSC_EXIT -ne 0 ]; then
  exit $TSC_EXIT
fi

# Run tests
echo "=== Tests: $(date) ===" >> .husky/logs/test.log
pnpm test 2>&1 | tee -a .husky/logs/test.log
exit ${PIPESTATUS[0]}