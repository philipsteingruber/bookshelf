# Create logs directory if it doesn't exist
mkdir -p .husky/logs

# Run TypeScript type checking first (fail fast)
echo "=== TypeScript check: $(date) ===" >> .husky/logs/tsc.log
pnpm exec tsc --noEmit 2>&1 | tee -a .husky/logs/tsc.log
TSC_EXIT=${PIPESTATUS[0]}

if [ $TSC_EXIT -ne 0 ]; then
  exit $TSC_EXIT
fi

# Get staged files for later use
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | tr '\n' ' ')

# Run ESLint on staged files and auto-fix
echo "=== ESLint run: $(date) ===" >> .husky/logs/eslint.log
git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$' | xargs --no-run-if-empty pnpm exec eslint --fix 2>&1 | tee -a .husky/logs/eslint.log
ESLINT_EXIT=${PIPESTATUS[0]}
git add -u

if [ $ESLINT_EXIT -ne 0 ]; then
  exit $ESLINT_EXIT
fi

# Run related tests if there are staged TS/TSX files
if [ -n "$STAGED_FILES" ]; then
  echo "=== Vitest run: $(date) ===" >> .husky/logs/vitest.log
  pnpm exec vitest run --related $STAGED_FILES --passWithNoTests 2>&1 | tee -a .husky/logs/vitest.log
  exit ${PIPESTATUS[0]}
fi
