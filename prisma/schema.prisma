// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id      String @id @default(cuid())
    clerkId String @unique

    name  String
    email String @unique

    defaultReadingThreshold Int @default(200)

    books Book[]

    createdAt         DateTime          @default(now())
    updatedAt         DateTime          @updatedAt
    readingProgresses ReadingProgress[]
    readingGoals      ReadingGoal[]

    @@index([clerkId])
    @@index([email])
}

model ReadingGoal {
    id String @id @default(cuid())

    year Int
    goal Int @default(20)

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String

    @@unique([userId, year])
    @@index([year, userId])
}

enum ReadStatus {
    TO_READ
    READING
    READ
    READ_NEXT
    DNF
}

model Book {
    id Int @id @default(autoincrement())

    title      String
    titleSort  String
    author     String
    authorSort String

    pageCount Int @default(0)
    progress  Int @default(0)

    rating          Int?
    goodreadsRating Decimal?
    goodreadsUrl    String?
    googleBooksUrl  String?
    review          String?  @db.Text

    coverUrl String?

    isbn String?

    series      String?
    seriesIndex Int?

    publishedYear Int

    summary String? @db.Text

    status ReadStatus @default(TO_READ)

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String

    startedAt         DateTime?
    finishedAt        DateTime?
    createdAt         DateTime          @default(now())
    updatedAt         DateTime          @updatedAt
    readingProgresses ReadingProgress[]

    @@unique([series, seriesIndex, userId])
    @@unique([isbn, userId])
    @@index([userId])
    @@index([status])
    @@index([author])
    @@index([series])
    @@index([rating])
    @@index([status, userId])
}

model ReadingProgress {
    id String @id @default(cuid())

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
    userId String
    bookId Int

    progress Int

    comments String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([bookId])
}
